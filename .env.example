# Curie Application Environment Variables
# Copy this file to .env and fill in your actual values

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Application URLs
# Local:
PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Production (example — use your real domains):
# PUBLIC_URL=https://api.automifyyai.com
# FRONTEND_URL=https://automifyyai.com

# Frontend build (Next.js) — must point the browser at your API
# NEXT_PUBLIC_API_URL=https://api.automifyyai.com

# Meta OAuth — redirect URIs must match exactly what you add in Meta Developer Console
# META_REDIRECT_URI=https://api.automifyyai.com/api/integrations/whatsapp/callback
# META_INSTAGRAM_REDIRECT_URI=https://api.automifyyai.com/api/integrations/instagram/callback
# META_MESSENGER_REDIRECT_URI=https://api.automifyyai.com/api/integrations/messenger/callback

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Security Configuration
# IMPORTANT: Generate a strong random secret key for production!
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# Admin User Configuration (optional - for auto-creation on startup)
ADMIN_EMAIL=admin@curie.com
ADMIN_PASSWORD=your_secure_admin_password_here

# Logging
LOG_LEVEL=INFO

# Testing helper (optional): comma-separated emails that bypass subscription checks
SUBSCRIPTION_BYPASS_EMAILS=

# OpenAI API Key (optional - leave empty for rule-based AI)
OPENAI_API_KEY=
